    "framer-motion": "^11.2.10",
    "lucide-react": "^0.379.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0-pre.0",
